{
  "name": "electron-app",
  "version": "1.0.0",
  "description": "Happy Birthday Mani!!",
  "author": "Rithvik Sriram",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "dependencies": {
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "electron-store": "^8.2.0",
    "node-ical": "^0.25.5",
    "store": "^2.0.12"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.bloom.app",
    "productName": "Bloom",
    "mac": {
      "target": {
        "target": "dmg",
        "arch": ["universal"]
      },
      "category": "public.app-category.utilities",
      "entitlements": "entitlements.mac.plist",
      "entitlementsInherit": "entitlements.mac.plist",
      "hardenedRuntime": true
    },
    "directories": {
      "output": "dist"
    },
    "publish": null
  }
}